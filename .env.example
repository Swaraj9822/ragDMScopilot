AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
RAG_S3_BUCKET=my-rag-bucket
RAG_S3_KMS_KEY_ID=
RAG_INGESTION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/rag-ingestion-queue
LLAMA_CLOUD_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=rag-index
SECRETS_MANAGER_SECRET_ID=
CORS_ALLOWED_ORIGINS=http://localhost:3000
COPILOT_DB_HOST=localhost
COPILOT_DB_PORT=5432
COPILOT_DB_NAME=copilot
COPILOT_DB_USER=postgres
COPILOT_DB_PASSWORD=

# Request-level timeouts (seconds). 0 = disabled (not recommended).
RAG_REQUEST_TIMEOUT_QUERY_S=60
RAG_REQUEST_TIMEOUT_COPILOT_S=90
RAG_REQUEST_TIMEOUT_ASK_S=120

# Bedrock SDK read timeout per individual LLM/embedding call (seconds).
BEDROCK_READ_TIMEOUT_S=45

# --- LLM Provider Selection ---
# Which generation provider to use: "bedrock" (default) or "gemini"
LLM_PROVIDER=bedrock
GEMINI_MODEL_ID=gemini-1.5-pro
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
LLM_FALLBACK_TO_BEDROCK=false
GEMINI_READ_TIMEOUT_S=90
